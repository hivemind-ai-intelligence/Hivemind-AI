{
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@3",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "buildCommand": "cd artifacts/hivemind && npm install && npm run build",
  "outputDirectory": "artifacts/hivemind/dist",
  "installCommand": "npm install -g pnpm@10 && pnpm install --no-frozen-lockfile",
  "framework": null
}
