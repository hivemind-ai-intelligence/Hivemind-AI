{
  "functions": {
    "api/[...path].ts": {
      "runtime": "@vercel/node@3",
      "maxDuration": 30,
      "memory": 512
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "installCommand": "npm install -g pnpm@10 && pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/hivemind run build",
  "outputDirectory": "artifacts/hivemind/dist",
  "framework": null
}
