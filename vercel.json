{
  "functions": {
    "api/[...path].js": {
      "runtime": "@vercel/node@3",
      "maxDuration": 30,
      "memory": 512
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "installCommand": "npm install -g pnpm@10 && pnpm install --force --no-frozen-lockfile",
  "buildCommand": "pnpm run build && cp -r dist ../../",
  "outputDirectory": "dist"
}
