{
  "functions": {
    "api/[...path].ts": {
      "runtime": "@vercel/node@3",
      "maxDuration": 30,
      "memory": 512
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "installCommand": "npm install -g pnpm@10 && pnpm install --no-frozen-lockfile",
  "buildCommand": "ROOT=$(pwd) && pnpm --filter @workspace/hivemind run build && cp -r \"$ROOT/artifacts/hivemind/dist\" $ROOT/",
  "outputDirectory": "dist"
}
